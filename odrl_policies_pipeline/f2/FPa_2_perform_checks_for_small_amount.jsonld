  "permission": [
    {
      "uid": "http://example.com/rules/smallAmountRule",
      "target": "http://example.com/asset/perform-checks-for-small-amount",
      "assigner": "http://example.com/FinancialBank:org:FB",
      "assignee": "http://example.com/staff/FinancialBank:org:FB",
      "action": [
        {
          "rdf:value": {
