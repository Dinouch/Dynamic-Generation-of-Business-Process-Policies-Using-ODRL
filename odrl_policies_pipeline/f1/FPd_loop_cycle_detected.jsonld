{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:cycle_detected-f1",
  "obligation": [
    {
      "uid": "http://example.com/rule:obligation-enable-check-for-completeness-working-hours",
      "target": "http://example.com/asset/check-for-completeness",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "odrl:dateTime",
          "operator": "odrl:gteq",
          "rightOperand": {
            "@value": "08:00",
            "@type": "xsd:time"
          }
        },
        {
          "leftOperand": "odrl:dateTime",
          "operator": "odrl:lteq",
          "rightOperand": {
            "@value": "18:00",
            "@type": "xsd:time"
          }
        }
      ]
    }
  ]
}