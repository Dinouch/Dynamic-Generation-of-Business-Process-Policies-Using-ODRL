{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "uid": "http://example.com/policy:201",
  "@type": "Agreement",
  "obligation": [
    {
      "uid": "http://example.com/rules/completenessCheckRule",
      "target": "http://example.com/asset/check-for-completeness",
      "assigner": "http://example.com/FinancialBank:org:FB",
      "assignee": "http://example.com/staff/FinancialBank:org:FB",
      "action": [
        {
          "rdf:value": {
            "@id": "odrl:trigger"
          },
          "refinement": [
            {
              "leftOperand": "dateTime",
              "operator": "gteq",
              "rightOperand": {
                "@value": "08:00",
                "@type": "xsd:time"
              }
            },
            {
              "leftOperand": "dateTime",
              "operator": "lteq",
              "rightOperand": {
                "@value": "18:00",
                "@type": "xsd:time"
              }
            }
          ]
        }
      ]
    }
  ]
}