{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:documentation-followup-f3",
  "permission": [
    {
      "uid": "http://example.com/policy:documentation-followup-f3#perm-1",
      "target": "http://example.com/asset/receive-missing-documents",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "http://example.com/odrl/operand/event",
          "operator": "odrl:eq",
          "rightOperand": "documents-received"
        }
      ]
    }
  ]
}