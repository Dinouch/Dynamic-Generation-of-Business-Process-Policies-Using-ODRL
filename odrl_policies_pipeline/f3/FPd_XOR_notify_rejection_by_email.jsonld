{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "uid": "http://example.com/policy:FPd_XOR_ca8f81a9",
  "@type": "Set",
  "permission": [
    {
      "uid": "http://example.com/rules/XOR_ij_notify_rejection_by_email_310c1fc7",
      "target": "http://example.com/rules/rejectionNotifyRule",
      "action": [
        {
          "rdf:value": {
            "@id": "odrl:enable"
          },
          "refinement": [
            {
              "leftOperand": "product",
              "operator": "eq",
              "rightOperand": "rejected"
            }
          ]
        }
      ]
    },
    {
      "uid": "http://example.com/rules/XOR_ik_notify_acceptance_by_email_d21cd673",
      "target": "http://example.com/rules/emailNotifyingRule",
      "action": [
        {
          "rdf:value": {
            "@id": "odrl:enable"
          },
          "refinement": [
            {
              "leftOperand": "product",
              "operator": "eq",
              "rightOperand": "accepted"
            }
          ]
        }
      ]
    }
  ]
}