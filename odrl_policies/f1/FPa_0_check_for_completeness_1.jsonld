{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "uid": "http://example.com/policy:FPa_check_for_completeness_ec923d3d",
  "@type": "Set",
  "permission": [
    {
      "uid": "http://example.com/rules/rule_check_for_completeness",
      "target": "http://example.com/asset/check_for_completeness",
      "action": "trigger",
      "constraint": [
        {
          "leftOperand": "dateTime",
          "operator": "gteq",
          "rightOperand": {
            "@value": "2024-01-01",
            "@type": "xsd:date"
          }
        }
      ]
    }
  ]
}