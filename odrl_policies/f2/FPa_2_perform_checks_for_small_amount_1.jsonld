{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "uid": "http://example.com/policy:FPa_perform_checks_for_small_amount_9e6cc92f",
  "@type": "Set",
  "permission": [
    {
      "uid": "http://example.com/rules/rule_perform_checks_for_small_amount",
      "target": "http://example.com/asset/perform_checks_for_small_amount",
      "action": "trigger",
      "constraint": [
        {
          "leftOperand": "dateTime",
          "operator": "gteq",
          "rightOperand": {
