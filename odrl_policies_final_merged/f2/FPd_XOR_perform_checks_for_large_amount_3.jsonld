{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "uid": "http://example.com/policy:FPd_XOR_7bde2831",
  "@type": "Set",
  "permission": [
    {
      "uid": "http://example.com/rules/XOR_ij_perform_checks_for_large_amount_2c95fa42",
      "target": "http://example.com/rules/largeAmountRule",
      "action": [
        {
          "rdf:value": {
            "@id": "odrl:enable"
          },
          "refinement": [
            {
              "leftOperand": "product",
              "operator": "eq",
              "rightOperand": ">500"
            }
          ]
        }
      ]
    },
    {
      "uid": "http://example.com/rules/XOR_ik_perform_checks_for_small_amount_ae60b869",
      "target": "http://example.com/rules/largeAmountRule",
      "action": [
        {
          "rdf:value": {
            "@id": "odrl:enable"
          },
          "refinement": [
            {
              "leftOperand": "product",
              "operator": "eq",
              "rightOperand": "<=500"
            }
          ]
        }
      ]
    }
  ]
}