{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:fragment-f2-documentation-follow-up-deadline-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy:fragment-f2-obligation-handle-documentation-deadline",
      "target": "http://example.com/asset/handle-documentation-deadline",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documentation-deadline"
        },
        {
          "leftOperand": "bpmn:gateway",
          "operator": "eq",
          "rightOperand": "documentation-follow-up"
        },
        {
          "leftOperand": "bpmn:gatewayType",
          "operator": "eq",
          "rightOperand": "fork_event_based_exclusive"
        },
        {
          "leftOperand": "bpmn:selection",
          "operator": "eq",
          "rightOperand": "firstEventWins"
        }
      ]
    }
  ]
}