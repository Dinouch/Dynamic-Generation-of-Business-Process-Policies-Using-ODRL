{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "uid": "http://example.com/policy:FPa_request_credit_card_6f609a86",
  "@type": "Agreement",
  "obligation": [
    {
      "uid": "http://example.com/rules/creditCardRequestRule",
      "target": "http://example.com/asset/request-credit-card",
      "assigner": "http://example.com/FinancialBank:org:FB",
      "assignee": "http://example.com/staff/FinancialBank:org:FB",
      "action": [
        {
          "rdf:value": {
            "@id": "odrl:trigger"
          },
          "refinement": [
            {
              "leftOperand": "meteredTime",
              "operator": "lteq",
              "rightOperand": {
                "@value": "PT24H",
                "@type": "xsd:duration"
              }
            },
            {
              "leftOperand": "systemDevice",
              "operator": "eq",
              "rightOperand": "http://example.com/system/InternalCreditSystem"
            }
          ]
        }
      ]
    }
  ]
}