{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "uid": "http://example.com/policy:FPa_receive_missing_documents_4b6a995d",
  "@type": "Agreement",
  "permission": [
    {
      "uid": "http://example.com/rules/receiveMissingDocumentsRule",
      "target": "http://example.com/asset/receive-missing-documents",
      "assigner": "http://example.com/FinancialBank:org:FB",
      "assignee": "http://example.com/staff/FinancialBank:org:FB",
      "action": [
        {
          "rdf:value": {
            "@id": "odrl:trigger"
          },
          "refinement": [
            {
              "leftOperand": "event",
              "operator": "eq",
              "rightOperand": "documents-received"
            }
          ]
        }
      ]
    }
  ]
