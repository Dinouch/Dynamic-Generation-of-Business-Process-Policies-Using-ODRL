{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/f3-documentation-follow-up-deadline-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy/f3/documentation-follow-up/obligation/handle-documentation-deadline-on-deadline-event",
      "target": "http://example.com/asset/handle-documentation-deadline",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documentation-deadline"
        },
        {
          "leftOperand": "bpmn:gateway",
          "operator": "eq",
          "rightOperand": "documentation-follow-up"
        },
        {
          "leftOperand": "bpmn:instantiation",
          "operator": "eq",
          "rightOperand": "firstEventWins"
        }
      ]
    }
  ]
}