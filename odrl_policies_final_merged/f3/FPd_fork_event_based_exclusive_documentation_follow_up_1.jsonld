{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:documentation-follow-up-f3-documentation-deadline-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy:documentation-follow-up-f3-documentation-deadline-obligation#rule1",
      "target": "http://example.com/asset/handle-documentation-deadline",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documentation-deadline"
        },
        {
          "leftOperand": "bpmn:gateway",
          "operator": "eq",
          "rightOperand": "documentation-follow-up"
        },
        {
          "leftOperand": "bpmn:fragment",
          "operator": "eq",
          "rightOperand": "f3"
        }
      ]
    }
  ]
}