{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/f3-documentation-followup-documents-received-enable",
  "permission": [
    {
      "uid": "http://example.com/policy/f3/rule/permit-enable-receive-missing-documents-on-documents-received-first",
      "target": "http://example.com/asset/receive-missing-documents",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documents-received"
        },
        {
          "leftOperand": "bpmn:gateway",
          "operator": "eq",
          "rightOperand": "documentation-followup"
        },
        {
          "leftOperand": "bpmn:exclusiveFirstEvent",
          "operator": "eq",
          "rightOperand": true
        }
      ]
    }
  ]
}