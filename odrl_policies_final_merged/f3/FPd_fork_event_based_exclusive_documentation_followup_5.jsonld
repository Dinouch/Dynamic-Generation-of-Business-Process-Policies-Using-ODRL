{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/documentation-followup-f3-deadline-first-event-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy/documentation-followup-f3-deadline-first-event-obligation#obligation-1",
      "target": "http://example.com/asset/handle-documentation-deadline",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documentation-deadline"
        },
        {
          "leftOperand": "bpmn:gateway",
          "operator": "eq",
          "rightOperand": "documentation-followup"
        },
        {
          "leftOperand": "bpmn:fragment",
          "operator": "eq",
          "rightOperand": "f3"
        },
        {
          "leftOperand": "bpmn:firstEventWins",
          "operator": "eq",
          "rightOperand": true
        }
      ]
    }
  ]
}