{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/f3-documentation-followup-deadline-first-event-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy/rule/f3-obligation-handle-documentation-deadline-if-first-event",
      "target": "http://example.com/asset/handle-documentation-deadline",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documentation-deadline"
        },
        {
          "leftOperand": "http://example.com/odrl/operand/firstEventAtGateway",
          "operator": "eq",
          "rightOperand": "http://example.com/bpmn/gateway/documentation-followup"
        }
      ]
    }
  ]
}