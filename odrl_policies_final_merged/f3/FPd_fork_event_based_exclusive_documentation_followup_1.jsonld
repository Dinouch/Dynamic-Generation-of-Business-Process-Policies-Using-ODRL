{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/f3-documentation-followup-deadline-permission",
  "permission": [
    {
      "uid": "http://example.com/policy/f3-documentation-followup-deadline-permission/rule/1",
      "target": "http://example.com/asset/handle-documentation-deadline",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documentation-deadline"
        },
        {
          "leftOperand": "bpmn:gateway",
          "operator": "eq",
          "rightOperand": "documentation-followup"
        },
        {
          "leftOperand": "bpmn:gatewayMode",
          "operator": "eq",
          "rightOperand": "eventBasedExclusiveFirstEventWins"
        }
      ]
    }
  ]
}