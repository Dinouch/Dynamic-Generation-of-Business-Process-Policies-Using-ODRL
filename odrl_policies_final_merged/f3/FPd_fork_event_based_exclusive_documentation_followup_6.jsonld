{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:f3-documentation-followup-receive-missing-documents-permission",
  "permission": [
    {
      "uid": "http://example.com/policy:f3/rule:permit-enable-receive-missing-documents-on-documents-received-first",
      "target": "http://example.com/asset/receive-missing-documents",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "http://example.com/odrl/operand/event",
          "operator": "odrl:eq",
          "rightOperand": "documents-received"
        },
        {
          "leftOperand": "http://example.com/odrl/operand/bpmnGateway",
          "operator": "odrl:eq",
          "rightOperand": "documentation-followup"
        },
        {
          "leftOperand": "http://example.com/odrl/operand/bpmnExclusiveFirstEvent",
          "operator": "odrl:eq",
          "rightOperand": true
        }
      ]
    }
  ]
}