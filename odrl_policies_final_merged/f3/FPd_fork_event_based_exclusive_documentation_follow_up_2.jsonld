{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/f3-documentation-follow-up-documents-received-first",
  "permission": [
    {
      "uid": "http://example.com/policy/f3-documentation-follow-up-documents-received-first/perm/enable-receive-missing-documents",
      "target": "http://example.com/asset/receive-missing-documents",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "documents-received"
        },
        {
          "leftOperand": "bpmn:gateway",
          "operator": "eq",
          "rightOperand": "documentation-follow-up"
        },
        {
          "leftOperand": "bpmn:instantiation",
          "operator": "eq",
          "rightOperand": "firstEventWins"
        }
      ]
    }
  ]
}