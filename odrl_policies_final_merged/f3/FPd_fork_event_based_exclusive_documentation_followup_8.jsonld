{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/f3-documentation-followup-documents-received-first",
  "permission": [
    {
      "uid": "http://example.com/policy/f3-documentation-followup-documents-received-first/perm/1",
      "target": "http://example.com/asset/receive-missing-documents",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "http://example.com/odrl/operand/event",
          "operator": "odrl:eq",
          "rightOperand": "documents-received"
        },
        {
          "leftOperand": "http://example.com/odrl/operand/firstEventAtGateway",
          "operator": "odrl:eq",
          "rightOperand": "http://example.com/bpmn/gateway/documentation-followup"
        }
      ]
    }
  ]
}