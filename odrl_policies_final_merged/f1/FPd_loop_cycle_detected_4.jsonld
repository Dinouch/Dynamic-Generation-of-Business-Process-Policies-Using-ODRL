{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/loop-f1-completeness-iteration",
  "obligation": [
    {
      "uid": "http://example.com/policy/loop-f1-completeness-iteration#obligation-1",
      "target": "http://example.com/asset/check-for-completeness",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "cycle_detected"
        },
        {
          "leftOperand": "odrl:sequence",
          "operator": "eq",
          "rightOperand": [
            "http://example.com/asset/check-for-completeness",
            "http://example.com/asset/ask-for-more-information"
          ]
        },
        {
          "leftOperand": "odrl:repetition",
          "operator": "gteq",
          "rightOperand": {
            "@value": 1,
            "@type": "xsd:integer"
          }
        },
        {
          "leftOperand": "odrl:until",
          "operator": "eq",
          "rightOperand": "completeness_met"
        }
      ]
    }
  ]
}