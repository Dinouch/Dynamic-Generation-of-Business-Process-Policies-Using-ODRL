{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:loop-f1-completeness-check-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy:rule/obligation-enable-check-for-completeness-on-loop-iteration",
      "target": "http://example.com/asset/check-for-completeness",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "cycle_detected"
        },
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "loop_iteration"
        },
        {
          "leftOperand": "purpose",
          "operator": "eq",
          "rightOperand": "completeness_evaluation"
        }
      ]
    }
  ]
}