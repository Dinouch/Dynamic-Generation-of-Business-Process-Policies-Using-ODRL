{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:loop-f1-ask-for-more-information-permission",
  "permission": [
    {
      "uid": "http://example.com/policy:loop-f1-ask-for-more-information-permission#perm1",
      "target": "http://example.com/asset/ask-for-more-information",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "http://example.com/odrl/operand/event",
          "operator": "odrl:eq",
          "rightOperand": "cycle_detected"
        }
      ]
    }
  ]
}