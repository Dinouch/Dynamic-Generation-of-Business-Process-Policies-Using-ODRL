{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/loop-f1-completeness-iteration-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy/loop-f1-completeness-iteration-obligation#obligation-ask-more-info",
      "target": "http://example.com/asset/ask-for-more-information",
      "action": {
        "@id": "odrl:trigger"
      },
      "constraint": [
        {
          "leftOperand": "http://example.com/operand/event",
          "operator": "odrl:eq",
          "rightOperand": "completeness-status:not-complete"
        }
      ]
    }
  ]
}