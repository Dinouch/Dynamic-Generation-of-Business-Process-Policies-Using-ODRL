{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/loop-f1-ask-more-info-only-when-incomplete",
  "permission": [
    {
      "uid": "http://example.com/policy/loop-f1-ask-more-info-only-when-incomplete/perm/1",
      "target": "http://example.com/asset/ask-for-more-information",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "http://example.com/odrl/operand/event",
          "operator": "odrl:eq",
          "rightOperand": "cycle_detected"
        },
        {
          "leftOperand": "http://example.com/odrl/operand/status",
          "operator": "odrl:eq",
          "rightOperand": "incomplete"
        }
      ]
    }
  ]
}