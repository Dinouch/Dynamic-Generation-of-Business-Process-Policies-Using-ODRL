{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy/loop-f1-completeness-retrigger",
  "obligation": [
    {
      "uid": "http://example.com/policy/loop-f1-completeness-retrigger/duty/1",
      "target": "http://example.com/asset/check-for-completeness",
      "action": {
        "@id": "odrl:trigger"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "cycle_detected"
        },
        {
          "leftOperand": "count",
          "operator": "gteq",
          "rightOperand": 1
        }
      ]
    }
  ]
}