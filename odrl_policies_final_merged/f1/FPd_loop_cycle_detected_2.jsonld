{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:loop-f1-cycle_detected-obligation",
  "obligation": [
    {
      "uid": "http://example.com/policy:loop-f1-cycle_detected-obligation#duty-1",
      "target": "http://example.com/asset/check-for-completeness",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "cycle_detected"
        },
        {
          "leftOperand": "count",
          "operator": "gteq",
          "rightOperand": {
            "@value": 1,
            "@type": "xsd:integer"
          }
        }
      ]
    }
  ]
}