{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:loop-f1-cycle_detected-completeness-check",
  "obligation": [
    {
      "uid": "http://example.com/policy:loop-f1-cycle_detected-completeness-check#obligation-1",
      "target": "http://example.com/asset/check-for-completeness",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "event",
          "operator": "eq",
          "rightOperand": "cycle_detected"
        },
        {
          "leftOperand": "odrl:hasPart",
          "operator": "isAnyOf",
          "rightOperand": [
            "http://example.com/asset/ask-for-more-information",
            "http://example.com/asset/check-for-completeness"
          ]
        },
        {
          "leftOperand": "dateTime",
          "operator": "gteq",
          "rightOperand": {
            "@value": "08:00",
            "@type": "xsd:time"
          }
        },
        {
          "leftOperand": "dateTime",
          "operator": "lteq",
          "rightOperand": {
            "@value": "18:00",
            "@type": "xsd:time"
          }
        }
      ]
    }
  ]
}