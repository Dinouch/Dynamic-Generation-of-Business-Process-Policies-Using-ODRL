      "action": [
        {
          "rdf:value": {
            "@id": "odrl:transfer"
          },
          "refinement": [
            {
              "leftOperand": "recipient",
              "operator": "eq",
              "rightOperand": "http://example.com/rules/receiveMissingDocumentsRule"
