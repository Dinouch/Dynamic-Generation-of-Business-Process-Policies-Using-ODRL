{
  "@context": "http://www.w3.org/ns/odrl.jsonld",
  "@type": "Set",
  "uid": "http://example.com/policy:documentation-follow-up-first-event-documents-received-permission",
  "permission": [
    {
      "uid": "http://example.com/policy:rule:permit-enable-receive-missing-documents-on-first-documents-received",
      "target": "http://example.com/asset/receive-missing-documents",
      "action": {
        "@id": "odrl:enable"
      },
      "constraint": [
        {
          "leftOperand": "http://example.com/odrl/operand/event",
          "operator": "odrl:eq",
          "rightOperand": "documents-received"
        },
        {
          "leftOperand": "http://example.com/odrl/operand/bpmnGateway",
          "operator": "odrl:eq",
          "rightOperand": "documentation-follow-up"
        },
        {
          "leftOperand": "http://example.com/odrl/operand/bpmnEventBasedGatewayOutcome",
          "operator": "odrl:eq",
          "rightOperand": "first"
        }
      ]
    }
  ]
}